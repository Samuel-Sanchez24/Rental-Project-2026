@inject IMediator Mediator


@{
    Rental_Project_2026.Application.UseCases.Account.Queries.GetAccountUserInfo.UserAccountInfoDTO user = null;

    try
    {
        if (User.Identity?.IsAuthenticated == true)
        {
            string? userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(userId))
            {
                user = await Mediator.Send(new Rental_Project_2026.Application
                                                                 .UseCases
                                                                 .Account
                                                                 .Queries
                                                                 .GetAccountUserInfo
                                                                 .GetAccountUserInfoQuery { UserId = userId });

            }
        }

    }
    catch
    {

        user = null;
    }

}

<header id="header" class="header fixed-top d-flex align-items-center">

    <div class="d-flex align-items-center justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="logo d-flex align-items-center">
            <img src="~/images/LogoP.png" alt="AutoRent Colombia" class="main-logo">
        </a>
        <i class="bi bi-list toggle-sidebar-btn"></i>
    </div>

    <div class="search-bar">
        <form class="search-form d-flex align-items-center">
            <input type="text" name="query" placeholder="Buscar..." />
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
    </div>

    <nav class="header-nav ms-auto">
        <ul class="d-flex align-items-center">

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <li class="nav-item dropdown pe-3">

                    <a class="nav-link nav-profile d-flex align-items-center pe-0"
                           href="#"
                           data-bs-toggle="dropdown">

                        <img src="~/assets/img/profile-img.jpg"
                             alt="Perfil"
                             class="rounded-circle">

                        <span class="d-none d-md-block dropdown-toggle ps-2">
                            @User.Identity.Name
                        </span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-arrow profile">

                        <li class="dropdown-header">
                            <h6>@User.Identity.Name</h6>
                            <span>Usuario autenticado</span>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <a class="dropdown-item d-flex align-items-center"
                                   asp-controller="Home"
                                   asp-action="Index">
                                <i class="bi bi-house-door"></i>
                                <span>Inicio</span>
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="m-0">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="dropdown-item d-flex align-items-center border-0 bg-transparent w-100">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Cerrar sesión</span>
                                </button>
                            </form>
                        </li>

                    </ul>
                </li>
            }
            else
            {
                <li class="nav-item pe-3">
                    <a class="nav-link d-flex align-items-center"
                           asp-controller="Account"
                           asp-action="Login">

                        <i class="bi bi-box-arrow-in-right me-2"></i>

                        <span class="d-none d-md-block">
                            Iniciar sesión
                        </span>
                    </a>
                </li>
            }

        </ul>
    </nav>

</header>