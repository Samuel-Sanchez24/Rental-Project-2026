@model Rental_Project_2026.Web.DTOs.Users.UsersIndexViewModel
@using Rental_Project_2026.Domain.Entities
@{
    ViewData["Title"] = "Usuarios";
    int totalPages = Model.List.TotalPages == 0 ? 1 : Model.List.TotalPages;
}
<link rel="stylesheet" href="~/css/theme-dark.css" />

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item active">Usuarios</li>
        </ol>
    </nav>
</div>

<section class="section users-page">
    <div class="card users-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                <h5 class="card-title">Lista de usuarios</h5>
                <a asp-action="Create" class="btn btn-primary">Crear usuario</a>
            </div>

            <form method="get" asp-action="Index" class="row g-3 mb-4">
                <input type="hidden" name="page" value="1" />

                <div class="col-md-3">
                    <label for="nameFilter" class="form-label">Nombre</label>
                    <input id="nameFilter" name="nameFilter" class="form-control" value="@Model.FilterName" />
                </div>

                <div class="col-md-3">
                    <label for="emailFilter" class="form-label">Correo</label>
                    <input id="emailFilter" name="emailFilter" class="form-control" value="@Model.FilterEmail" />
                </div>

                <div class="col-md-2">
                    <label for="roleFilter" class="form-label">Rol</label>
                    <select id="roleFilter" name="roleFilter" class="form-select">
                        <option value="">Todos</option>
                        @foreach (UserRole role in Enum.GetValues<UserRole>())
                        {
                            if (Model.FilterRole == role)
                            {
                                <option value="@role" selected>@role</option>
                            }
                            else
                            {
                                <option value="@role">@role</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Estado</label>
                    <select id="statusFilter" name="statusFilter" class="form-select">
                        <option value="">Todos</option>
                        @foreach (UserStatus status in Enum.GetValues<UserStatus>())
                        {
                            if (Model.FilterStatus == status)
                            {
                                <option value="@status" selected>@status</option>
                            }
                            else
                            {
                                <option value="@status">@status</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="pageSize" class="form-label">Tamaño</label>
                    <select id="pageSize" name="pageSize" class="form-select">
                        @foreach (int size in new[] { 5, 10, 20, 50 })
                        {
                            if (Model.List.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>

            <table class="table table-bordered users-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Telefono</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.List.Items)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td>@item.Role</td>
                            <td class="user-status">@item.Status</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.id" class="btn btn-sm btn-info">
                                    Ver
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.id" class="btn btn-sm btn-warning">
                                    Editar
                                </a>

                                @if (item.Status.ToString() == "Active")
                                {
                                    <button type="button" class="btn btn-sm btn-danger btnToggleStatus" data-id="@item.id">
                                        Desactivar
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-success btnToggleStatus" data-id="@item.id">
                                        Activar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-between align-items-center mt-3">
                @if (Model.List.HasPreviousPage)
                {
                    <a asp-action="Index"
                       asp-route-page="@(Model.List.PageNumber - 1)"
                       asp-route-pageSize="@Model.List.PageSize"
                       asp-route-nameFilter="@Model.FilterName"
                       asp-route-emailFilter="@Model.FilterEmail"
                       asp-route-roleFilter="@Model.FilterRole"
                       asp-route-statusFilter="@Model.FilterStatus"
                       class="btn btn-outline-primary">
                        Anterior
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary" disabled>Anterior</button>
                }

                <span class="fw-semibold">
                    Pagina @Model.List.PageNumber / @totalPages
                </span>

                @if (Model.List.HasNextPage)
                {
                    <a asp-action="Index"
                       asp-route-page="@(Model.List.PageNumber + 1)"
                       asp-route-pageSize="@Model.List.PageSize"
                       asp-route-nameFilter="@Model.FilterName"
                       asp-route-emailFilter="@Model.FilterEmail"
                       asp-route-roleFilter="@Model.FilterRole"
                       asp-route-statusFilter="@Model.FilterStatus"
                       class="btn btn-outline-primary">
                        Siguiente
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary" disabled>Siguiente</button>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('.btnToggleStatus').click(function () {

                const button = $(this);
                const id = button.data('id');

                Swal.fire({
                    icon: "question",
                    title: "¨Desea cambiar el estado del usuario?",
                    text: "El usuario cambiar  su estado actual.",
                    showCancelButton: true,
                    confirmButtonText: "Sí",
                    cancelButtonText: "Cancelar",
                    background: "#0b1e33",
                    color: "#ffffff",
                    confirmButtonColor: "#4f46e5",
                    cancelButtonColor: "#6c757d"
                }).then((result) => {

                    if (result.isConfirmed) {

                        $.ajax({
                            url: '/Users/ToggleStatus',
                            type: 'POST',
                            data: { id: id },
                            success: function (response) {

                                if (response.success) {
                                    Swal.fire({
                                        icon: "success",
                                        title: "Estado actualizado",
                                        text: response.message,
                                        timer: 1200,
                                        background: "#0b1e33",
                                        showConfirmButton: false
                                    }).then(() => {
                                        location.reload();
                                    });
                                }
                                else {
                                    Swal.fire("Error", response.message, "error");
                                }
                            }
                        });

                    }
                });
            });

        });
    </script>
}
