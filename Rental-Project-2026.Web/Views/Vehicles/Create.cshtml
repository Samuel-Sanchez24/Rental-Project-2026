@model Rental_Project_2026.Web.DTOs.Vehicles.CreateVehicleDTO
@using Rental_Project_2026.Domain.Enums

@{
    ViewData["Title"] = "Crear vehículo";
}

<link rel="stylesheet" href="~/css/theme-dark.css" />

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" asp-controller="Home">Inicio</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" asp-controller="Vehicles">Vehículos</a>
            </li>
            <li class="breadcrumb-item active">Crear</li>
        </ol>
    </nav>
</div>

<section class="section dashboard branch-page">

    <div class="card branch-card">

        <div class="card-header">
            <div class="row align-items-center">
                <h3 class="m-0 font-weight-bold col-md-11 branch-title">
                    Registrar vehículo
                </h3>

                <div class="col-md-1 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body mt-3">

            <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="col-md-4">
                    <label asp-for="Plate" class="form-label"></label>
                    <input asp-for="Plate" class="form-control" placeholder="Ej: ABC123" />
                    <span asp-validation-for="Plate" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Brand" class="form-label"></label>
                    <input asp-for="Brand" class="form-control" placeholder="Ej: Toyota" />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Model" class="form-label"></label>
                    <input asp-for="Model" class="form-control" placeholder="Ej: Corolla" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Color" class="form-label"></label>
                    <input asp-for="Color" class="form-control" placeholder="Ej: Blanco" />
                    <span asp-validation-for="Color" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Year" class="form-label"></label>
                    <input asp-for="Year" type="number" class="form-control" placeholder="Ej: 2024" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DailyPrice" class="form-label"></label>
                    <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" placeholder="Ej: 180000" />
                    <span asp-validation-for="DailyPrice" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status"
                            asp-items="Html.GetEnumSelectList<VehicleStatus>()"
                            class="form-select">
                        <option value="">Seleccione un estado</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="BranchId" class="form-label"></label>
                    <select asp-for="BranchId" asp-items="Model.Branches" class="form-select">
                        <option value="">Seleccione una sucursal</option>
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="ImageFile" class="form-label"></label>

                    <label for="ImageFile" class="vehicle-upload-box" id="vehicleUploadBox">
                        <input asp-for="ImageFile"
                               id="ImageFile"
                               type="file"
                               class="d-none"
                               accept="image/*" />

                        <div class="vehicle-upload-content">
                            <i class="bi bi-cloud-arrow-up fs-1"></i>
                            <h5>Subir imagen del vehículo</h5>
                            <p>Haz clic aquí o arrastra una imagen</p>
                            <span>Formatos permitidos: JPG, JPEG, PNG o WEBP</span>
                        </div>

                        <div class="vehicle-upload-preview d-none" id="vehicleImagePreviewContainer">
                            <img id="vehicleImagePreview" src="#" alt="Vista previa del vehículo" />
                        </div>
                    </label>

                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Guardar vehículo
                    </button>
                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const imageInput = document.getElementById("ImageFile");
        const uploadBox = document.getElementById("vehicleUploadBox");
        const previewContainer = document.getElementById("vehicleImagePreviewContainer");
        const previewImage = document.getElementById("vehicleImagePreview");

        imageInput.addEventListener("change", function () {
            showPreview(this.files[0]);
        });

        uploadBox.addEventListener("dragover", function (e) {
            e.preventDefault();
            uploadBox.classList.add("vehicle-upload-box-active");
        });

        uploadBox.addEventListener("dragleave", function () {
            uploadBox.classList.remove("vehicle-upload-box-active");
        });

        uploadBox.addEventListener("drop", function (e) {
            e.preventDefault();
            uploadBox.classList.remove("vehicle-upload-box-active");

            const file = e.dataTransfer.files[0];

            if (file) {
                imageInput.files = e.dataTransfer.files;
                showPreview(file);
            }
        });

        function showPreview(file) {
            if (!file) {
                return;
            }

            if (!file.type.startsWith("image/")) {
                Swal.fire({
                    icon: "error",
                    title: "Archivo no válido",
                    text: "Debes seleccionar una imagen.",
                    background: "#0b1e33",
                    color: "#ffffff",
                    confirmButtonColor: "#0d6efd"
                });

                imageInput.value = "";
                return;
            }

            const reader = new FileReader();

            reader.onload = function (e) {
                previewImage.src = e.target.result;
                previewContainer.classList.remove("d-none");
            };

            reader.readAsDataURL(file);
        }
    </script>
}