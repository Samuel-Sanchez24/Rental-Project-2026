@model Rental_Project_2026.Web.DTOs.Account.LoginDTO

@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesión";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>Iniciar sesión - AutoRent Colombia</title>

    <meta content="Sistema de renta de vehículos AutoRent Colombia" name="description">
    <meta content="renta, vehículos, reservas, sucursales, login" name="keywords">

    @await Html.PartialAsync("_Styles")
    <link href="~/css/theme-dark.css" rel="stylesheet" asp-append-version="true" />
</head>

<body>

    <main class="login-page">
        <div class="login-wrapper">

            <section class="login-brand-panel">

                <div class="login-brand">
                    <img src="~/images/Favicon.png" alt="AutoRent Colombia">

                    <div class="login-brand-title">
                        <strong>AutoRent</strong>
                        <span>Colombia</span>
                    </div>
                </div>

                <div class="login-hero-text">
                    <h1>
                        Bienvenido a <span>AutoRent Colombia</span>
                    </h1>

                    <p>
                        La forma más fácil, rápida y segura de <span>alquilar tu carro</span>.
                    </p>

                    <div class="login-tags">
                        <span class="login-tag">
                            <i class="bi bi-shield-check"></i> Acceso seguro
                        </span>

                        <span class="login-tag">
                            <i class="bi bi-car-front"></i> Vehículos
                        </span>

                        <span class="login-tag">
                            <i class="bi bi-geo-alt"></i> Sucursales
                        </span>
                    </div>
                </div>

                <div class="login-copyright">
                    © @DateTime.Now.Year AutoRent Colombia. Todos los derechos reservados.
                </div>

            </section>

            <section class="login-panel">
                <div class="login-card">

                    <div class="login-title">
                        <h2>Iniciar sesión</h2>
                        <p>Ingresa tus credenciales para acceder al sistema</p>
                    </div>

                    <form asp-controller="Account" asp-action="Login" method="post" class="row g-3">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <div class="col-12">
                            <label asp-for="Email" class="form-label">Correo electrónico</label>

                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope"></i>
                                </span>

                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="ejemplo@correo.com"
                                       autocomplete="username" />
                            </div>

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Password" class="form-label">Contraseña</label>

                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>

                                <input asp-for="Password"
                                       class="form-control"
                                       placeholder="Ingrese su contraseña"
                                       autocomplete="current-password" />
                            </div>

                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       asp-for="RememberMe">

                                <label class="form-check-label" asp-for="RememberMe">
                                    Recordarme
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <button class="btn btn-login w-100" type="submit">
                                <i class="bi bi-box-arrow-in-right me-1"></i>
                                Ingresar
                            </button>
                        </div>

                        <div class="login-footer-note">
                            Sistema interno de gestión de vehículos, usuarios y reservas.
                        </div>

                    </form>

                </div>
            </section>

        </div>
    </main>

    @await Html.PartialAsync("_Scripts")

    @{
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
        
    @await Component.InvokeAsync("Notyf")
    }





</body>

</html>