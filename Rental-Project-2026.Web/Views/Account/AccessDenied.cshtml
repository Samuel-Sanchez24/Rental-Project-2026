@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>

    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
            </li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="card">
        <div class="card-body text-center py-5">

            <div class="mb-4">
                <i class="bi bi-shield-lock text-warning" style="font-size: 4rem;"></i>
            </div>

            <h4 class="card-title mb-3">No tienes permiso para acceder a este recurso</h4>

            <p class="text-muted mb-4">
                Tu usuario no cuenta con los permisos necesarios para ingresar a esta sección de AutoRent Colombia.
                Si crees que esto es un error, comunícate con el administrador del sistema.
            </p>

            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-house-door"></i>
                    Volver al inicio
                </a>

                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Iniciar sesión
                </a>
            </div>

        </div>
    </div>
</section>